# .env ve benzeri gizli dosyalara dışarıdan erişimi engelle
# NOT: Bu XAMPP Apache derlemesi .htaccess içinde <IfModule> kabul etmiyor;
# mod_authz_core yüklü olduğundan doğrudan Require kullanılır.
<FilesMatch "^\.(env|env\.example|gitignore)$">
    Require all denied
</FilesMatch>

# .git klasörünün TAMAMINA web erişimini engelle (kaynak kodu/geçmişi ifşa eder)
RewriteEngine On
RewriteRule "(^|/)\.git" - [F,L]

# Directory listing kapalı
Options -Indexes

# PHP hata gösterimini kapat
php_flag display_errors off
php_flag log_errors on
